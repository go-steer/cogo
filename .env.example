# Cogo / spike environment — copy to .env and source before running.
#
# Two auth paths, pick one:

# ── Option A: Vertex AI (production setup for this project) ──────────────────
export GOOGLE_GENAI_USE_VERTEXAI=true
export GOOGLE_CLOUD_PROJECT=gke-demos-345619
export GOOGLE_CLOUD_LOCATION=global
# Auth: gcloud auth application-default login

# ── Option B: Public Gemini API ──────────────────────────────────────────────
# unset GOOGLE_GENAI_USE_VERTEXAI
# export GOOGLE_API_KEY=...

# ── Optional: OpenTelemetry exporter (off by default) ────────────────────────
# export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# export OTEL_SERVICE_NAME=cogo
