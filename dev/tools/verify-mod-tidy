#!/usr/bin/env bash
# Fail when go.mod / go.sum are not in `go mod tidy` form.
set -euo pipefail
. "$(dirname "$0")/common.sh"
cd "$(repo_root)"

go mod tidy
if ! git diff --quiet -- go.mod go.sum; then
  echo "go.mod / go.sum are not tidy. Run 'go mod tidy' locally and commit the result." >&2
  git diff -- go.mod go.sum >&2
  exit 1
fi
