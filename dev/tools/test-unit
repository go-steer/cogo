# Run the unit test suite with -race + atomic coverage.
#
# Outputs coverage.out at the repo root for the CI summary step.
# Vertex E2E tests are gated on COGO_E2E=1 + auth env vars and skip
# automatically when those aren't set.
set -euo pipefail
. "$(dirname "$0")/common.sh"
cd "$(repo_root)"

exec go test -race -timeout 5m \
  -coverprofile=coverage.out -covermode=atomic \
  ./...
